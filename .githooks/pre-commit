#!/usr/bin/env bash
# Orpheus pre-commit hook — keeps CI green by catching format + clippy issues
# before they hit the branch. Skip with `git commit --no-verify` only when you
# absolutely know what you're doing.

set -euo pipefail

if ! command -v mise >/dev/null 2>&1; then
    echo "pre-commit: mise not on PATH; skipping checks" >&2
    exit 0
fi

exec mise run pre-commit
