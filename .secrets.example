# Example secrets file for running release workflows locally with `act`.
#
# Copy to `.secrets` (gitignored) and fill in real values. KEY=VALUE format,
# no quotes, no export. `act` reads this via its default `--secret-file`.
#
#   cp .secrets.example .secrets
#   # edit .secrets
#   act workflow_dispatch -W .github/workflows/publish-cask.yml \
#     --input tag=v0.0.0-smoke
#
# DO NOT commit `.secrets`. It's gitignored; `.secrets.example` is safe.

# --- Homebrew cask publishing ---
# Fine-grained PAT scoped to the homebrew-orpheus tap repo, Contents: write.
HOMEBREW_TAP_TOKEN=github_pat_REPLACE_ME

# --- crates.io publishing ---
# Scoped token from https://crates.io/settings/tokens
CARGO_REGISTRY_TOKEN=cio_REPLACE_ME

# --- GPG release signing ---
# Base64-encoded ASCII-armored private subkey. One-liner to produce:
#   gpg --armor --export-secret-subkeys <SUBKEY_ID>! | base64 | pbcopy
GPG_PRIVATE_KEY=
GPG_PASSPHRASE=
GPG_KEY_ID=

# --- Apple Developer ID (when ready) ---
APPLE_CERTIFICATE=
APPLE_CERTIFICATE_PASSWORD=
APPLE_SIGNING_IDENTITY=
APPLE_TEAM_ID=
APPLE_API_KEY=
APPLE_API_KEY_ID=
APPLE_API_ISSUER=

# --- SignPath (when approved) ---
SIGNPATH_API_TOKEN=

# --- GitHub token — act injects a stub GITHUB_TOKEN by default ---
# Set this only if a step needs full repo access (e.g. gh release upload).
# Use a short-lived fine-grained PAT, NEVER your personal ghp_ PAT.
# GITHUB_TOKEN=
